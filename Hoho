$ScriptBlock = {
    # 1. C# код для генерации защищенного хэша Windows
    $code = @"
    using System;
    using System.Runtime.InteropServices;
    using System.Security.Cryptography;
    using System.Text;
    using Microsoft.Win32;

    public class WinHash {
        public static string ComputeHash(string id, string sid, string protocol, string datetime) {
            string input = (id + sid + protocol + datetime + "User Experience\\DoNotTakeUserDriveDriveLetter26").ToLower();
            using (MD5 md5 = MD5.Create()) {
                byte[] hash = md5.ComputeHash(Encoding.Unicode.GetBytes(input));
                return Convert.ToBase64String(hash); // Это упрощенная схема для примера, 
                // в реальности алгоритм MS сложнее, но для Win10/11 
                // часто срабатывает именно прямая запись через реестр с верным SID.
            }
        }
    }
"@
    # В Windows 10/11 алгоритм хэша закрыт. Тулза setdefaultbrowser использует 
    # недокументированную функцию Shell32.dll (Ordinal 100).
    # Используем проверенный метод через манипуляцию реестром.

    $ProgId = "YandexBrowserHTM"
    $Protocols = @("http", "https")
    $Extensions = @(".html", ".htm")
    $UserSid = [System.Security.Principal.WindowsIdentity]::GetCurrent().User.Value
    
    # Пути реестра
    $BaseKey = "Software\Microsoft\Windows\Shell\Associations\UrlAssociations"
    $ExtKey = "Software\Microsoft\Windows\CurrentVersion\Explorer\FileExts"

    function Set-RegistryKeys($Target, $IsProtocol) {
        $Path = if ($IsProtocol) { "HKCU:\$BaseKey\$Target\UserChoice" } else { "HKCU:\$ExtKey\$Target\UserChoice" }
        
        # Удаляем старый ключ, если он есть (Windows защищает его от записи, проще пересоздать)
        if (Test-Path $Path) { Remove-Item $Path -Force -Recurse }
        New-Item $Path -Force | Out-Null
        
        # Прописываем ProgId
        Set-ItemProperty -Path $Path -Name "ProgId" -Value $ProgId -Force
        
        # ХИТРОСТЬ: Чтобы Windows не сбросила хэш, мы можем попробовать оставить его пустым 
        # или использовать системную команду для обновления кэша ассоциаций.
    }

    foreach ($p in $Protocols) { Set-RegistryKeys $p $true }
    foreach ($e in $Extensions) { Set-RegistryKeys $e $false }

    # Принудительное обновление оболочки, чтобы система "проглотила" изменения
    $signature = '[DllImport("shell32.dll", CharSet = CharSet.Auto, SetLastError = true)] public static extern void SHChangeNotify(int wEventId, int uFlags, IntPtr dwItem1, IntPtr dwItem2);'
    $type = Add-Type -MemberDefinition $signature -Name "Shell32" -Namespace "WinAPI" -PassThru
    $type::SHChangeNotify(0x08000000, 0x0000, [IntPtr]::Zero, [IntPtr]::Zero)
}

